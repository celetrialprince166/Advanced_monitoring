# =============================================================================
# Jenkins .env Template
# =============================================================================
# This file documents ALL environment variables consumed by jenkins.yaml (JCasC)
#
# HOW TO USE:
#   1. Run ./generate-jenkins-env.sh to auto-populate from terraform outputs
#   2. Manually fill in JENKINS_AWS_ACCESS_KEY_ID and JENKINS_AWS_SECRET_ACCESS_KEY
#   3. Optionally change JENKINS_ADMIN_USER / JENKINS_ADMIN_PASSWORD
#
# WARNING: The real .env file contains secrets — it is gitignored.
# =============================================================================

# --- Jenkins Admin ---
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin

# --- AWS Credentials (MANUAL — not in terraform outputs) ---
JENKINS_AWS_ACCESS_KEY_ID=
JENKINS_AWS_SECRET_ACCESS_KEY=

# --- AWS Region ---
JENKINS_AWS_REGION=

# --- ECR ---
JENKINS_ECR_REGISTRY=

# --- EC2 Deployment ---
JENKINS_EC2_HOST=
JENKINS_EC2_SSH_KEY=

# --- Database ---
JENKINS_DB_USERNAME=
JENKINS_DB_PASSWORD=
JENKINS_DB_NAME=

# --- SonarCloud ---
JENKINS_SONAR_TOKEN=

# --- Slack ---
JENKINS_SLACK_TOKEN=

# --- CodeDeploy ---
JENKINS_CODEDEPLOY_APP=
JENKINS_CODEDEPLOY_DG=

# --- ECS ---
JENKINS_ECS_ALB_DNS=
JENKINS_ECS_CLUSTER=
JENKINS_ECS_SERVICE=
JENKINS_ECS_EXEC_ROLE=
JENKINS_ECS_TASK_ROLE=

# --- Observability ---
JENKINS_OTEL_ENDPOINT=
